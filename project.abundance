                                    {
                                      "atomType": "Code",
                                      "x": 0.5509259259259259,
                                      "y": 0.2590529247910863,
                                      "uniqueID": "id-105216",
                                      "ioValues": [
                                        {
                                          "name": "shape",
                                          "ioValue": "__GEOMETRY_INPUT__"
                                        },
