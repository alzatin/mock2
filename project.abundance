                                  "atomType": "Code",
                                  "x": 0.6058201058201058,
                                  "y": 0.6350974930362118,
                                  "uniqueID": "id-106876",
                                  "ioValues": [
                                    {
                                      "name": "shape",
                                      "ioValue": "__GEOMETRY_INPUT__"
                                    },
